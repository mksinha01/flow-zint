// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

// ─── USERS & WORKSPACES ──────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedWorkspaces Workspace[]
  memberships     WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner            User               @relation(fields: [ownerId], references: [id])
  members          WorkspaceMember[]
  businessContext  BusinessContext?
  documents        BusinessDocument[]
  agentConfigs     AgentConfig[]
  leads            Lead[]
  calls            Call[]
  bookings         Booking[]
  learningInsights LearningInsight[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("MEMBER")
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
}

// ─── BUSINESS ONBOARDING ─────────────────────────────────────────────────────

model BusinessContext {
  id                 String   @id @default(cuid())
  workspaceId        String   @unique
  companyName        String
  productDescription String
  targetCustomer     String
  keyPainPoints      String
  pricing            String?
  competitorNames    String?
  callObjective      String // "book_demo" | "qualify" | "sell_direct"
  voiceStyle         String   @default("FORMAL")
  additionalNotes    String?
  sellingStyle       String   @default("CONSULTATIVE")
  entrapmentOptions  String?
  updatedAt          DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model BusinessDocument {
  id            String   @id @default(cuid())
  workspaceId   String
  fileName      String
  fileType      String // pdf | docx | txt
  fileUrl       String // R2 URL
  extractedText String
  uploadedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── AI AGENT CONFIGURATION ──────────────────────────────────────────────────

model AgentConfig {
  id                    String    @id @default(cuid())
  workspaceId           String
  version               Int
  status                String    @default("DRAFT")
  systemPrompt          String
  openingScript         String
  qualifyingQuestions   String // string[]
  objectionHandlers     String // { objection: string, response: string }[]
  generatedFromInsights String? // LearningInsight ids that triggered this version
  generatedAt           DateTime  @default(now())
  activatedAt           DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  calls     Call[]

  @@unique([workspaceId, version])
}

// ─── LEADS ───────────────────────────────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  phone       String
  email       String?
  company     String?
  jobTitle    String?
  status      String   @default("NEW")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  calls     Call[]
  bookings  Booking[]
}

// ─── CALLS ───────────────────────────────────────────────────────────────────

model Call {
  id            String    @id @default(cuid())
  workspaceId   String
  leadId        String
  agentConfigId String?
  livekitRoomId String?
  status        String    @default("QUEUED")
  duration      Int? // seconds
  recordingUrl  String? // R2 URL
  transcript    String?
  startedAt     DateTime?
  endedAt       DateTime?
  createdAt     DateTime  @default(now())

  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead        Lead          @relation(fields: [leadId], references: [id])
  agentConfig AgentConfig?  @relation(fields: [agentConfigId], references: [id])
  analysis    CallAnalysis?
  booking     Booking?
}

model CallAnalysis {
  id              String   @id @default(cuid())
  callId          String   @unique
  workspaceId     String
  sentiment       String
  leadScore       Int // 1–100
  classification  String
  objections      String // { text: string, timestamp: number, handled: boolean }[]
  buyingIntent    Boolean
  intentReasoning String
  summary         String
  createdAt       DateTime @default(now())

  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)
}

// ─── LEARNING ENGINE ─────────────────────────────────────────────────────────

model LearningInsight {
  id               String   @id @default(cuid())
  workspaceId      String
  sourceCallIds    String // string[] — call IDs that generated this insight
  insightType      String
  description      String
  suggestion       String
  appliedToVersion Int? // AgentConfig version that applied this
  createdAt        DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

// ─── BOOKINGS ────────────────────────────────────────────────────────────────

model Booking {
  id                    String    @id @default(cuid())
  workspaceId           String
  callId                String    @unique
  leadId                String
  calendlyEventUri      String?
  scheduledAt           DateTime?
  confirmationEmailSent Boolean   @default(false)
  createdAt             DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  call      Call      @relation(fields: [callId], references: [id])
  lead      Lead      @relation(fields: [leadId], references: [id])
}

# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/flowzint

# ─── APP ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=10000
FRONTEND_URL=https://flow-zint-frontend.onrender.com

# ─── AUTH ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── GOOGLE GEMINI ───────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── LIVEKIT ─────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SIP_OUTBOUND_TRUNK_ID=SIPTxxxxxxxxxx
LIVEKIT_WEBHOOK_SECRET=your-webhook-secret

# ─── STT / TTS ───────────────────────────────────────────────────────────────
SARVAM_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# ─── CLOUDFLARE R2 ───────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=flowzint-storage
R2_PUBLIC_URL=https://your-bucket.r2.dev

# ─── RESEND (EMAIL) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@flowzint.ai

# ─── CALENDLY (OPTIONAL) ──────────────────────────────────────────────────────
CALENDLY_API_KEY=your-calendly-api-key
CALENDLY_EVENT_TYPE_URI=https://api.calendly.com/event_types/...

# ─── HUBSPOT CRM (OPTIONAL) ───────────────────────────────────────────────────
HUBSPOT_API_KEY=your-hubspot-api-key

# ─── LEARNING LOOP ────────────────────────────────────────────────────────────
LEARNING_TRIGGER_AFTER_N_CALLS=10
